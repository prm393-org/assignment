rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cart items are private per Firebase Auth uid — the multi-device
    // sync in CartNotifier reads/writes only its own doc.
    match /carts/{uid}/items/{productId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Anyone signed in may bump commentCount when posting/deleting a
    // comment; all other post fields stay author-only.
    function onlyCommentCountChanged() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['commentCount']);
    }

    // Forum stays public-read (matches ForumRepositoryImpl's pre-Firestore
    // behavior); only the author may create/edit/delete their own post.
    match /forum_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid
        || onlyCommentCountChanged()
      );
      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.authorId == request.auth.uid;
      }
    }

    // Notifications are written by whoever triggers the event (e.g. the
    // commenter notifying a post's author), not only by the recipient, so
    // create only validates the caller is signed in and the payload names
    // itself correctly. Only the recipient may read or mark their own
    // notification as read.
    match /notifications/{notificationId} {
      allow create: if isSignedIn()
        && request.resource.data.userId is string;
      allow read, update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }
  }
}
