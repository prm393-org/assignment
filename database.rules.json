{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "presence_lookup": {
      "$backendUserId": {
        ".read": "auth != null",
        ".write": "auth != null && newData.child('firebaseUid').val() == auth.uid"
      }
    },
    "chat_messages": {
      "$conversationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["createdAtMs"]
      }
    },
    "order_status": {
      "$orderId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "notification_unread": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null"
      }
    }
  }
}
